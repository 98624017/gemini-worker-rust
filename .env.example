# Core
PORT=8787
UPSTREAM_BASE_URL=https://magic666.top
UPSTREAM_API_KEY=replace-me

# Proxy wrapping
PUBLIC_BASE_URL=
ALLOWED_PROXY_DOMAINS=ai.kefan.cn,uguu.se,.uguu.se,.aitohumanize.com

# output=url
IMAGE_HOST_MODE=legacy
PROXY_STANDARD_OUTPUT_URLS=1
UPLOAD_TIMEOUT_MS=20000

# Legacy upload endpoints
LEGACY_UGUU_UPLOAD_URL=https://uguu.se/upload
LEGACY_KEFAN_UPLOAD_URL=https://ai.kefan.cn/api/upload/local

# R2 settings
# Enable when IMAGE_HOST_MODE=r2 or r2_then_legacy
R2_ENDPOINT=
R2_BUCKET=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_PUBLIC_BASE_URL=
R2_OBJECT_PREFIX=images
